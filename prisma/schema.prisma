// DSA Prep platform schema.
// Single source of truth for problems, submissions, sheets, and streaks.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth.js v5 (standard adapter tables) ----------

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  username      String?          @unique
  timezone      String           @default("UTC")
  longestStreak Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  accounts        Account[]
  sessions        Session[]
  handles         PlatformHandle[]
  submissions     Submission[]
  notes           Note[]
  sheetProgress   UserSheetProgress[]
  streakDays      StreakDay[]
  snapshots       LeaderboardSnapshot[]

  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Platform integration ----------

enum Platform {
  LEETCODE
  CODEFORCES
}

model PlatformHandle {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform
  handle       String
  verifyToken  String?
  verifiedAt   DateTime?
  lastSyncedAt DateTime?
  // Cached "distinct problems solved" count from the upstream platform.
  // For LEETCODE: submitStatsGlobal.acSubmissionNum where difficulty='All'.
  // For CODEFORCES: COUNT(DISTINCT problemId) over local AC Submission rows.
  solvedCount  Int?
  solvedEasy   Int?
  solvedMedium Int?
  solvedHard   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, handle])
  @@index([platform, verifiedAt])
}

// ---------- Problems ----------

enum Difficulty {
  EASY
  MEDIUM
  HARD
  UNKNOWN
}

model Problem {
  id          String      @id @default(cuid())
  platform    Platform
  externalId  String
  slug        String
  title       String
  url         String
  difficulty  Difficulty  @default(UNKNOWN)
  rating      Int?
  contestId   String?
  isPremium   Boolean     @default(false)
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  topics       ProblemTopic[]
  submissions  Submission[]
  notes        Note[]
  sheetEntries SheetProblem[]

  @@unique([platform, externalId])
  @@index([platform, difficulty])
  @@index([platform, rating])
  @@index([slug])
}

model Topic {
  id       String         @id @default(cuid())
  name     String         @unique
  slug     String         @unique
  problems ProblemTopic[]
}

model ProblemTopic {
  problemId String
  topicId   String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([problemId, topicId])
  @@index([topicId])
}

enum Verdict {
  AC
  WA
  TLE
  MLE
  RE
  CE
  OTHER
}

model Submission {
  id           String   @id @default(cuid())
  userId       String
  problemId    String
  platform     Platform
  externalId   String?
  verdict      Verdict
  language     String?
  submittedAt  DateTime
  source       String?
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, externalId])
  @@index([userId, submittedAt])
  @@index([userId, problemId])
  @@index([userId, verdict, submittedAt])
}

// ---------- Sheets (curated lists like Striver / NeetCode) ----------

model Sheet {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  source      String?
  description String?
  createdAt   DateTime       @default(now())

  sections SheetSection[]
  problems SheetProblem[]
}

model SheetSection {
  id      String  @id @default(cuid())
  sheetId String
  name    String
  order   Int     @default(0)

  sheet    Sheet          @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  problems SheetProblem[]

  @@index([sheetId, order])
}

model SheetProblem {
  id        String  @id @default(cuid())
  sheetId   String
  sectionId String?
  problemId String
  order     Int     @default(0)
  notes     String?

  sheet    Sheet               @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  section  SheetSection?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  problem  Problem             @relation(fields: [problemId], references: [id], onDelete: Cascade)
  progress UserSheetProgress[]

  @@unique([sheetId, problemId])
  @@index([sectionId, order])
}

enum SheetStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model UserSheetProgress {
  id             String      @id @default(cuid())
  userId         String
  sheetProblemId String
  status         SheetStatus @default(PENDING)
  completedAt    DateTime?
  updatedAt      DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheetProblem SheetProblem @relation(fields: [sheetProblemId], references: [id], onDelete: Cascade)

  @@unique([userId, sheetProblemId])
  @@index([userId, status])
}

// ---------- Notes ----------

model Note {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  contentMd String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

// ---------- Contests ----------

model Contest {
  id          String   @id @default(cuid())
  platform    Platform
  externalId  String
  name        String
  url         String
  startsAt    DateTime
  durationMin Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([platform, externalId])
  @@index([startsAt])
}

// ---------- Streaks & Leaderboard ----------

model StreakDay {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  solvedCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model LeaderboardSnapshot {
  id            String   @id @default(cuid())
  userId        String
  periodStart   DateTime @db.Date
  weeklySolved  Int      @default(0)
  totalSolved   Int      @default(0)
  cfRating      Int?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([periodStart, weeklySolved])
}
