# Database (Neon Postgres)
# DATABASE_URL: pooled URL (used at runtime by the app)
# DIRECT_URL:   non-pooled URL (used by `prisma migrate`). Remove "-pooler" segment from host.
DATABASE_URL=""
DIRECT_URL=""

# Auth.js v5
# Generate via: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Cron protection (random shared secret for /api/cron/*)
CRON_SECRET=""

# LeetCode GraphQL endpoint
LEETCODE_GRAPHQL_URL="https://leetcode.com/graphql/"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
